      </extract>
      <layout dim-ordering='alphabetic' measure-ordering='alphabetic' show-structure='true' />
      <style>
        <style-rule element='mark'>
          <encoding attr='color' field='[none:Crash_Nature:nk]' palette='cyclic_10_0' type='palette'>
            <map to='#1ba3c6'>
              <bucket>&quot;Angle&quot;</bucket>
            </map>
            <map to='#25b392'>
              <bucket>&quot;Fall from vehicle&quot;</bucket>
            </map>
            <map to='#33bcbe'>
              <bucket>&quot;Collision - miscellaneous&quot;</bucket>
            </map>
            <map to='#34a559'>
              <bucket>&quot;Head-on&quot;</bucket>
            </map>
            <map to='#4f7cba'>
              <bucket>&quot;Struck by internal load&quot;</bucket>
            </map>
            <map to='#78ab30'>
              <bucket>&quot;Hit animal&quot;</bucket>
            </map>
            <map to='#8670c2'>
              <bucket>&quot;Struck by external load&quot;</bucket>
            </map>
            <map to='#c26abf'>
              <bucket>&quot;Sideswipe&quot;</bucket>
            </map>
            <map to='#cdbb21'>
              <bucket>&quot;Hit object&quot;</bucket>
            </map>
            <map to='#e23b25'>
              <bucket>&quot;Non-collision - miscellaneous&quot;</bucket>
            </map>
            <map to='#ec73b2'>
              <bucket>&quot;Rear-end&quot;</bucket>
            </map>
            <map to='#ee3852'>
              <bucket>&quot;Other&quot;</bucket>
            </map>
            <map to='#f88113'>
              <bucket>&quot;Hit pedestrian&quot;</bucket>
            </map>
            <map to='#f8b11f'>
              <bucket>&quot;Hit parked vehicle&quot;</bucket>
            </map>
            <map to='#f9608b'>
              <bucket>&quot;Overturned&quot;</bucket>
            </map>
          </encoding>
          <encoding attr='color' field='[none:Crash_Speed_Limit:nk]' type='palette'>
            <map to='#4e79a7'>
              <bucket>&quot;60 km/h&quot;</bucket>
            </map>
            <map to='#59a14f'>
              <bucket>&quot;70 km/h&quot;</bucket>
            </map>
            <map to='#76b7b2'>
              <bucket>&quot;80 - 90 km/h&quot;</bucket>
            </map>
            <map to='#e15759'>
              <bucket>&quot;0 - 50 km/h&quot;</bucket>
            </map>
            <map to='#edc948'>
              <bucket>%null%</bucket>
            </map>
            <map to='#f28e2b'>
              <bucket>&quot;100 - 110 km/h&quot;</bucket>
            </map>
          </encoding>
          <encoding attr='color' field='[none:Crash_Severity:nk]' palette='blue_teal_10_0' type='palette'>
            <map to='#2c5985'>
              <bucket>&quot;Property damage only&quot;</bucket>
            </map>
            <map to='#347da0'>
              <bucket>&quot;Minor injury&quot;</bucket>
            </map>
            <map to='#45a2b9'>
              <bucket>&quot;Medical treatment&quot;</bucket>
            </map>
            <map to='#81c3cb'>
              <bucket>&quot;Hospitalisation&quot;</bucket>
            </map>
            <map to='#bce4d8'>
              <bucket>&quot;Fatal&quot;</bucket>
            </map>
          </encoding>
          <encoding attr='color' field='[none:Loc_Local_Government_Area:nk]' palette='blue_teal_10_0' type='palette'>
            <map to='#2c5985'>
              <bucket>&quot;Yarrabah Aboriginal Shire&quot;</bucket>
            </map>
            <map to='#2c5a86'>
              <bucket>&quot;Wujal Wujal Aboriginal Shire&quot;</bucket>
            </map>
            <map to='#2c5c87'>
              <bucket>&quot;Woorabinda Aboriginal Shire&quot;</bucket>
            </map>
            <map to='#2d5e89'>
              <bucket>&quot;Winton Shire&quot;</bucket>
            </map>
            <map to='#2d5f8a'>
